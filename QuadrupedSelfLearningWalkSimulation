import mujoco
import mujoco.viewer
import numpy as np

QUAD_XML = """
<mujoco model="spot_v4">
    <compiler angle="degree" coordinate="local"/>
    <option timestep="0.002" iterations="50" solver="PGS" gravity="0 0 -9.81"/>
    
    <default>
        <joint damping="0.5" armature="0.01"/>
        <geom contype="1" conaffinity="1" friction="1.5 0.1 0.1"/>
        <motor ctrllimited="true" ctrlrange="-1 1"/>
    </default>

    <worldbody>
        <light directional="true" diffuse=".8 .8 .8" pos="0 0 5" dir="0 0 -1"/>
        <geom name="floor" type="plane" size="100 100 0.1" rgba=".2 .3 .4 1"/>
        
        <body name="torso" pos="0 0 0.45">
            <freejoint name="root"/>
            <geom name="chassis" type="box" size="0.25 0.13 0.07" rgba="0.9 0.8 0 1" mass="4.0"/>
            
            <body name="FL_hip" pos="0.2 0.13 0">
                <inertial pos="0 0 0" mass="0.2" diaginertia="0.001 0.001 0.001"/>
                <joint name="FL_a" type="hinge" axis="1 0 0" range="-20 20"/>
                <body name="FL_t" pos="0 0.02 0">
                    <joint name="FL_p" type="hinge" axis="0 1 0" range="-60 60"/>
                    <geom type="capsule" size="0.025" fromto="0 0 0 0 0 -0.16" mass="0.3"/>
                    <body name="FL_c" pos="0 0 -0.16">
                        <joint name="FL_k" type="hinge" axis="0 1 0" range="10 110"/>
                        <geom type="capsule" size="0.025" fromto="0 0 0 0 0 -0.16" mass="0.3"/>
                        <geom name="FL_foot" type="sphere" size="0.03" pos="0 0 -0.16" rgba="0 0 0 1"/>
                    </body>
                </body>
            </body>
            <body name="FR_hip" pos="0.2 -0.13 0">
                <inertial pos="0 0 0" mass="0.2" diaginertia="0.001 0.001 0.001"/>
                <joint name="FR_a" type="hinge" axis="1 0 0" range="-20 20"/>
                <body name="FR_t" pos="0 -0.02 0">
                    <joint name="FR_p" type="hinge" axis="0 1 0" range="-60 60"/>
                    <geom type="capsule" size="0.025" fromto="0 0 0 0 0 -0.16" mass="0.3"/>
                    <body name="FR_c" pos="0 0 -0.16">
                        <joint name="FR_k" type="hinge" axis="0 1 0" range="10 110"/>
                        <geom type="capsule" size="0.025" fromto="0 0 0 0 0 -0.16" mass="0.3"/>
                        <geom name="FR_foot" type="sphere" size="0.03" pos="0 0 -0.16" rgba="0 0 0 1"/>
                    </body>
                </body>
            </body>
            <body name="BL_hip" pos="-0.2 0.13 0">
                <inertial pos="0 0 0" mass="0.2" diaginertia="0.001 0.001 0.001"/>
                <joint name="BL_a" type="hinge" axis="1 0 0" range="-20 20"/>
                <body name="BL_t" pos="0 0.02 0">
                    <joint name="BL_p" type="hinge" axis="0 1 0" range="-60 60"/>
                    <geom type="capsule" size="0.025" fromto="0 0 0 0 0 -0.16" mass="0.3"/>
                    <body name="BL_c" pos="0 0 -0.16">
                        <joint name="BL_k" type="hinge" axis="0 1 0" range="10 110"/>
                        <geom type="capsule" size="0.025" fromto="0 0 0 0 0 -0.16" mass="0.3"/>
                        <geom name="BL_foot" type="sphere" size="0.03" pos="0 0 -0.16" rgba="0 0 0 1"/>
